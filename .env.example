# Copy to .env and fill in values: cp .env.example .env

# --- Better Auth ---
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000
# Optional: "true" | "false" to override HTTPS cookie behavior
# BETTER_AUTH_USE_SECURE_COOKIES=

# --- Aurora DSQL (IAM auth via AWS SDK; no postgres:// password URL) ---
AURORA_DSQL_HOST=
AURORA_DSQL_USER=admin
# Optional
# AURORA_DSQL_DATABASE=
# AURORA_DSQL_REGION=
# AURORA_DSQL_POOL_MAX=3

# --- AWS (DSQL token signing + S3) ---
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Optional: public base URL for direct S3/CDN image URLs (otherwise images are proxied via the API)
# S3_PUBLIC_URL_BASE=

# --- Google AI (image generation) ---
GOOGLE_GENERATIVE_AI_API_KEY=
